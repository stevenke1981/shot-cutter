<Page x:Class="ShotCutter.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:ShotCutter.App.ViewModels"
      xmlns:models="clr-namespace:ShotCutter.Core.Models;assembly=ShotCutter.Core"
      d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <ScrollViewer Margin="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600">
            <TextBlock Text="設定" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

            <!-- FFmpeg paths -->
            <TextBlock Text="FFmpeg 路徑" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

            <TextBlock Text="ffmpeg.exe" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Text="{Binding FFmpegPath, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="留空使用內建或 PATH" />
                <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Folder24}"
                           Command="{Binding BrowseFFmpegCommand}" Margin="4,0,0,0" />
            </Grid>

            <TextBlock Text="ffprobe.exe" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Text="{Binding FFprobePath, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="留空使用內建或 PATH" />
                <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Folder24}"
                           Command="{Binding BrowseFFprobeCommand}" Margin="4,0,0,0" />
            </Grid>

            <Separator Margin="0,0,0,16" />

            <!-- Defaults -->
            <TextBlock Text="預設值" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

            <TextBlock Text="預設擷取模式" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Source={StaticResource CaptureModeValues}}"
                      SelectedItem="{Binding DefaultMode}"
                      Margin="0,0,0,8" />

            <TextBlock Text="預設輸出格式" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Source={StaticResource OutputFormatValues}}"
                      SelectedItem="{Binding DefaultFormat}"
                      Margin="0,0,0,8" />

            <TextBlock Text="預設品質" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <Slider Minimum="1" Maximum="100" Value="{Binding DefaultQuality}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="{Binding DefaultQuality}" />
            </Grid>

            <TextBlock Text="最大平行任務數" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <Slider Minimum="1" Maximum="8" Value="{Binding MaxParallelTasks}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="{Binding MaxParallelTasks}" />
            </Grid>

            <Separator Margin="0,0,0,16" />

            <!-- Browser settings -->
            <TextBlock Text="瀏覽器設定" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

            <CheckBox Content="擷取完成後自動在瀏覽器開啟"
                      IsChecked="{Binding AutoOpenInBrowser}"
                      Margin="0,0,0,8" />

            <TextBlock Text="指定瀏覽器" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Text="{Binding BrowserPath, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="留空使用系統預設" />
                <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Folder24}"
                           Command="{Binding BrowseBrowserCommand}" Margin="4,0,0,0" />
            </Grid>

            <Separator Margin="0,0,0,16" />

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:Button Content="儲存設定" Appearance="Primary"
                           Icon="{ui:SymbolIcon Save24}"
                           Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <ui:Button Content="恢復預設" Appearance="Secondary"
                           Command="{Binding ResetDefaultsCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
