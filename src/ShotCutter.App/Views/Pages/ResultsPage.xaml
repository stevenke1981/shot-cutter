<Page x:Class="ShotCutter.App.Views.Pages.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:ShotCutter.App.ViewModels"
      d:DataContext="{d:DesignInstance vm:ResultsViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="結果瀏覽" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button Content="在瀏覽器中開啟"
                       Icon="{ui:SymbolIcon Globe24}"
                       Command="{Binding OpenInBrowserCommand}"
                       Margin="0,0,8,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Screenshots}"
                     SelectedItem="{Binding SelectedScreenshot}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                Padding="4" Width="200" Cursor="Hand"
                                ToolTip="{Binding ImagePath}">
                            <StackPanel>
                                <Image Source="{Binding ImagePath}" Height="120"
                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Text="{Binding Timestamp, StringFormat=hh\\:mm\\:ss\\.fff}"
                                           HorizontalAlignment="Center" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="1" Margin="16,0,0,0" Padding="16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="詳細資訊" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <Image Source="{Binding SelectedScreenshot.ImagePath}" Height="180"
                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />

                    <TextBlock Text="時間戳" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding SelectedScreenshot.Timestamp, StringFormat=hh\\:mm\\:ss\\.fff}" />

                    <TextBlock Text="檔案大小" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding SelectedScreenshot.FileSizeBytes, Converter={StaticResource FileSizeConverter}}" />

                    <TextBlock Text="路徑" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBlock Text="{Binding SelectedScreenshot.ImagePath}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <ui:Button Content="開啟選取圖片"
                               Command="{Binding OpenSingleImageCommand}"
                               Margin="0,16,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Empty state -->
        <TextBlock Grid.Row="2"
                   Text="尚未擷取截圖。請先到「擷取截圖」頁面開始擷取。"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   FontSize="14">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Screenshots.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,8,0,0" />
    </Grid>
</Page>
