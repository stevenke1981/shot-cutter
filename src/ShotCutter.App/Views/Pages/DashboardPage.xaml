<Page x:Class="ShotCutter.App.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:ShotCutter.App.ViewModels"
      xmlns:models="clr-namespace:ShotCutter.Core.Models;assembly=ShotCutter.Core"
      d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      AllowDrop="True"
      Drop="OnDrop"
      DragOver="OnDragOver">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="擷取截圖" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />

        <!-- Main content: Video list + Options side by side -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Video list panel -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <ui:Button Content="新增影片" Icon="{ui:SymbolIcon Add24}"
                                   Command="{Binding AddVideosCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="清空" Icon="{ui:SymbolIcon Delete24}"
                                   Appearance="Secondary"
                                   Command="{Binding ClearVideosCommand}" />
                    </StackPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding Videos}"
                              x:Name="VideoListView"
                              SelectionMode="Extended"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="檔案名稱" Width="220"
                                    DisplayMemberBinding="{Binding FileName}" />
                                <GridViewColumn Header="時長" Width="80"
                                    DisplayMemberBinding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" />
                                <GridViewColumn Header="解析度" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding Width, Mode=OneWay}" /><Run Text="×" /><Run Text="{Binding Height, Mode=OneWay}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="編碼" Width="70"
                                    DisplayMemberBinding="{Binding CodecName}" />
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="移除選取" Click="RemoveSelected_Click" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>

                    <!-- Empty state overlay -->
                    <TextBlock Grid.Row="1" Text="拖放影片檔案到此處，或點擊「新增影片」"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="14"
                               Visibility="{Binding VideoCount, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Visible}" />
                </Grid>
            </Border>

            <!-- Options panel -->
            <Border Grid.Column="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="擷取模式" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource CaptureModeValues}}"
                                  SelectedItem="{Binding SelectedMode}"
                                  Margin="0,0,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Interval mode options -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:CaptureMode.Interval}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="間隔秒數" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="0.5" Maximum="60"
                                        Value="{Binding IntervalSeconds}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="{Binding IntervalSeconds, StringFormat={}{0:0.#}s}" />
                            </Grid>
                        </StackPanel>

                        <!-- TimePoint mode options -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:CaptureMode.TimePoint}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="時間點 (逗號分隔，如: 0:01:30, 120.5)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding TimePointsText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" MinHeight="60"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- SceneChange mode options -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:CaptureMode.SceneChange}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="場景變化閾值" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="0.05" Maximum="0.95"
                                        Value="{Binding SceneChangeThreshold}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SceneChangeThreshold, StringFormat={}{0:0.00}}" />
                            </Grid>
                        </StackPanel>

                        <!-- FirstLastFrame mode options -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:CaptureMode.FirstLastFrame}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <CheckBox Content="擷取第一幀" IsChecked="{Binding CaptureFirstFrame}" Margin="0,0,0,4" />
                            <CheckBox Content="擷取最後一幀" IsChecked="{Binding CaptureLastFrame}" />
                        </StackPanel>

                        <!-- SmartScene mode options -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:CaptureMode.SmartScene}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="智慧場景分析：使用直方圖差異自動偵測場景切換，每個場景擷取代表幀。" />
                            <TextBlock Text="場景靈敏度" Margin="0,8,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="0.05" Maximum="0.95"
                                        Value="{Binding SceneChangeThreshold}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SceneChangeThreshold, StringFormat={}{0:0.00}}" />
                            </Grid>
                        </StackPanel>

                        <Separator Margin="0,4,0,12" />

                        <TextBlock Text="輸出設定" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                        <TextBlock Text="格式" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource OutputFormatValues}}"
                                  SelectedItem="{Binding SelectedFormat}"
                                  Margin="0,0,0,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="品質" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="100"
                                    Value="{Binding Quality}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Text="{Binding Quality}" />
                        </Grid>

                        <TextBlock Text="輸出資料夾" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="預設: 影片同目錄/ShotCutter_Output" />
                            <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Folder24}"
                                       Command="{Binding BrowseOutputDirectoryCommand}"
                                       Margin="4,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="2" Value="{Binding OverallProgress}"
                     Maximum="100" Height="6" Margin="0,12,0,0"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />

        <!-- Status bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,8,0,0" />

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="取消" Appearance="Secondary"
                       Command="{Binding CancelCaptureCommand}"
                       Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                       Margin="0,0,8,0" />
            <ui:Button Content="開始擷取" Appearance="Primary"
                       Icon="{ui:SymbolIcon Play24}"
                       Command="{Binding StartCaptureCommand}" />
        </StackPanel>
    </Grid>
</Page>
